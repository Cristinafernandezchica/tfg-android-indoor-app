<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Mapa -->
        <com.cristina.tfg_android_indoor_app.map.ZoomableImageView
            android:id="@+id/mapImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/piso_piloto_muebles"
            android:scaleType="matrix" />

        <com.cristina.tfg_android_indoor_app.map.RouteOverlayView
            android:id="@+id/routeOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <com.cristina.tfg_android_indoor_app.map.RoomInfoOverlayView
            android:id="@+id/roomInfoOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Botón menú flotante -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:src="@drawable/ic_menu_24"
            app:backgroundTint="?attr/colorSurface"
            app:tint="?attr/colorOnSurface"
            app:fabSize="normal" />

        <!-- Botón flotante para mostrar panel (aparece cuando está oculto) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnShowPanel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:src="@drawable/ic_chevron_up_24"
            android:visibility="gone"
            app:backgroundTint="?attr/colorPrimary"
            app:tint="@android:color/white"
            app:fabSize="mini" />

        <!-- Panel inferior deslizable -->
        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/bottomSheet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bottom_sheet_background"
                app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

                <!-- Handle para deslizar -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bottom_sheet_handle" />

                <!-- Contenido del panel -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnStartRoute"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:text="Iniciar ruta"
                            android:layout_marginEnd="8dp"
                            style="@style/Widget.Modern.Button"
                            app:icon="@drawable/ic_navigation_24"
                            app:iconGravity="textStart" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClearRoute"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:text="Borrar"
                            style="@style/Widget.Modern.Button.Outlined"
                            app:icon="@drawable/ic_delete_24"
                            app:iconGravity="textStart" />

                    </LinearLayout>

                    <!-- Navegación de pasos -->
                    <LinearLayout
                        android:id="@+id/layoutStepNavigation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/step_navigation_background"
                        android:padding="4dp"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPrevStep"
                            android:layout_width="52dp"
                            android:layout_height="44dp"
                            android:text="◀"
                            style="@style/Widget.Modern.Button.Text"
                            android:enabled="false" />

                        <TextView
                            android:id="@+id/tvStepCounter"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Paso 0/0"
                            android:textAlignment="center"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNextStep"
                            android:layout_width="52dp"
                            android:layout_height="44dp"
                            android:text="▶"
                            style="@style/Widget.Modern.Button.Text"
                            android:enabled="false" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnShowFullRoute"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="Ruta completa"
                        android:layout_marginBottom="8dp"
                        style="@style/Widget.Modern.Button.Text"
                        android:enabled="false" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnForceStart"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:text="Inicio desde ENTRADA"
                        android:layout_gravity="center_horizontal"
                        style="@style/Widget.Modern.Button.Text"
                        app:icon="@drawable/ic_location_24"
                        app:iconGravity="textStart"
                        android:textSize="12sp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:gravity="center" />

                </LinearLayout>

            </LinearLayout>

        </androidx.coordinatorlayout.widget.CoordinatorLayout>

    </FrameLayout>

    <!-- Menú lateral -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header_route"
        app:menu="@menu/route_menu" />

</androidx.drawerlayout.widget.DrawerLayout>