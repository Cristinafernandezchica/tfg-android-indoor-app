<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Contenido principal -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Imagen del mapa indoor -->
        <com.cristina.tfg_android_indoor_app.map.ZoomableImageView
            android:id="@+id/mapImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/piso_piloto_muebles"
            android:scaleType="matrix" />

        <!-- Overlay para dibujar rutas -->
        <com.cristina.tfg_android_indoor_app.map.RouteOverlayView
            android:id="@+id/routeOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:elevation="20dp" />

        <!-- Botón para abrir menú lateral -->
        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="16dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:backgroundTint="#2196F3"
            android:background="@drawable/rounded_button"
            android:scaleType="centerInside" />

        <!-- Botones inferiores -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:padding="16dp">

            <Button
                android:id="@+id/btnStartRoute"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Iniciar ruta"
                android:backgroundTint="#2196F3" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnPrevStep"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Anterior"
                    android:backgroundTint="#FF9800"
                    android:enabled="false"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnNextStep"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Siguiente"
                    android:backgroundTint="#4CAF50"
                    android:enabled="false"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnShowFullRoute"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ruta completa"
                    android:backgroundTint="#9C27B0"
                    android:enabled="false"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnClearRoute"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Borrar"
                    android:backgroundTint="#F44336"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <Button
                android:id="@+id/btnForceStart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Iniciar desde ENTRADA"
                android:layout_marginTop="8dp"
                android:backgroundTint="#FF9800" />

        </LinearLayout>

    </FrameLayout>

    <!-- Menú lateral -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header_route"
        app:menu="@menu/route_menu" />


</androidx.drawerlayout.widget.DrawerLayout>